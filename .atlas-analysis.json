  "keyFeatures": [
    "AI-powered card generation from CVs, certs, and portfolios using local AI providers",
    "Candidate-owned data: skill cards live in personal GitHub repos, never on a central server",
    "Rules of Engagement enforced by AI agents (salary floor, remote policy, blocked industries)",
    "Three-zone privacy model: public profile, verified details, private contact info",
    "Cross-platform CLI for macOS, Linux, and Windows (PowerShell)",
    "JSON Schema validation for protocol compliance",
    "EU AI Act compliant by design — no demographic fields, human-in-the-loop",
    "Extensible entity model: humans, AI agents, services, robots, teams, organizations"
  ],
  "publicApiSurface": [
    "scoutica init [directory]",
    "scoutica scan <docs-folder> [--with <provider>] [--output <dir>] [--clipboard]",
    "scoutica validate [directory]",
    "scoutica publish [directory]",
    "scoutica resolve <url> [save-dir]",
    "scoutica info [directory]",
    "scoutica doctor",
    "scoutica update",
    "profile.json — machine-readable professional profile",
    "rules.yaml — candidate rules of engagement",
    "evidence.json — verifiable public work links",
    "scoutica.json — discovery file (like robots.txt for AI agents)",
    "schemas/scoutica_discovery.schema.json — JSON Schema for discovery file"
  ]
}
